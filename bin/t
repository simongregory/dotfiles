#!/bin/bash

PROJ_DIR=$(git rev-parse --show-toplevel)

if [ -f "$PROJ_DIR/pnpm-workspace.yaml" ]; then
  echo "pnpm test $@"
  pnpm test "$@"
elif [ -f "$PROJ_DIR/package.json" ]; then
  #Using a prefix doesn't clear line and expand \r\033[K
  echo "npm test $@"
  npm test "$@"
elif [ -f "$PROJ_DIR/Rakefile" ]; then
  echo "rake test"
  rake test
else
  echo "t failed, unknown build system"
fi
