#!/bin/bash

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<EOF
Usage: t [args]

Runs tests for the current project, auto-detecting the build system:
  pnpm-lock.yaml    -> pnpm test [args]
  package-lock.json -> npm test [args]
  package.json      -> (suggests pnpm/npm install first)
  Rakefile          -> rake test
  Cargo.toml        -> cargo test [args]

Must be run from within a git repository.
EOF
  exit 0
fi

PROJ_DIR=$(git rev-parse --show-toplevel 2>/dev/null || pwd)

if [ -f "$PROJ_DIR/pnpm-lock.yaml" ]; then
  echo "pnpm test $@"
  pnpm test "$@"
elif [ -f "$PROJ_DIR/package-lock.json" ]; then
  #Using a prefix doesn't clear line and expand \r\033[K
  echo "npm test $@"
  npm test "$@"
elif [ -f "$PROJ_DIR/package.json" ]; then
  echo "No lockfile found. Run 'pnpm install' or 'npm install' first."
  exit 1
elif [ -f "$PROJ_DIR/Rakefile" ]; then
  echo "rake test"
  rake test
elif [ -f "$PROJ_DIR/Cargo.toml" ]; then
  echo "cargo test (t may need some work for --workspace detection) $@"
  cargo test "$@"
else
  echo "t failed, unknown build system"
fi
