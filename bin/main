#!/usr/bin/env bash

# Utility to switch to the default branch (main or master) in a git repository.

if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo "No repository found"
  exit 1
fi

if git show-ref --verify --quiet refs/heads/main; then
  git checkout main
elif git show-ref --verify --quiet refs/heads/master; then
  git checkout master
else
  # Try to detect the default branch from the remote, if possible
  default_branch=$(git remote show origin 2>/dev/null | awk '/HEAD branch/ {print $NF}')
  if [[ -n "$default_branch" ]]; then
    git checkout "$default_branch"
  else
    echo "Neither 'main' nor 'master' branch found, and could not detect remote default branch"
    exit 1
  fi
fi
